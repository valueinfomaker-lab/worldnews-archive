{% extends "base.html.j2" %}
{% block title %}{{ site_title }} — 세계뉴스 일일 브리핑{% endblock %}
{% block content %}
<header class="topbar">
  <div class="topbar-inner">
    <a class="brand" href="index.html" aria-label="GRIP 홈">
      <svg class="logo" aria-hidden="true"><use href="#logo"/></svg>
      <span class="wm">GR<i>I</i>P</span>
    </a>
    <button id="theme-toggle" class="iconbtn" type="button" aria-label="테마 전환" title="테마 전환"></button>
  </div>
</header>

<section class="hero">
  <div class="hero-inner">
    <div class="hero-lock">
      <svg class="hero-logo" aria-hidden="true"><use href="#logo"/></svg>
      <div>
        <div class="hero-wm">GR<i>I</i>P</div>
        <div class="hero-full">{{ site_full }}</div>
      </div>
    </div>
    <h1 class="hero-title">{{ site_tagline.split(', ')[0] }},<br><b>{{ site_tagline.split(', ')[1] }}</b></h1>
    <p class="hero-desc">{{ site_desc }}</p>
  </div>
</section>

<main class="wrap">
  {% if not days %}
    <p class="empty">아직 브리핑이 없습니다.</p>
  {% else %}
  <div class="sec-label">일일 브리핑 아카이브 <span>· 전체 {{ days|length }}일치</span></div>
  <ul class="date-list">
    {% for d in days %}
    <li class="date-card">
      <a class="date-main" href="{{ d.day }}.html">
        <span class="date">{{ d.day }}</span>
        <span class="count">{{ d.total }}건</span>
      </a>
      <div class="regions">
        {% for region, n in d.regions.items() %}<span class="chip-stat">{{ region }} <b>{{ n }}</b></span>{% endfor %}
      </div>
    </li>
    {% endfor %}
  </ul>
  {% endif %}
</main>

<footer class="connect" id="connect">
  <div class="connect-grid">
    <section class="connect-card" aria-labelledby="connect-nl">
      <div class="connect-head">
        <span class="connect-ico connect-ico-nl" aria-hidden="true">✉</span>
        <h2 class="connect-title" id="connect-nl">뉴스레터 구독</h2>
      </div>
      <p class="connect-desc">매일 아침, 권역별 핵심 브리핑을 이메일로 받아보세요.</p>
      <form class="sub-form" id="subscribe-form" data-endpoint="{{ subscribe_endpoint }}" novalidate>
        <div class="sub-fields">
          <input class="sub-input" type="text" name="name" id="sub-name" placeholder="이름" autocomplete="name" required>
          <input class="sub-input" type="email" name="email" id="sub-email" placeholder="이메일 주소" autocomplete="email" required>
          <button class="btn sub-btn" type="submit">구독 신청</button>
        </div>
        <p class="sub-status" id="sub-status" role="status" aria-live="polite" hidden></p>
        <p class="sub-note">신청 시 뉴스레터 수신에 동의하는 것으로 간주하며, 언제든 수신거부할 수 있습니다.</p>
      </form>
    </section>

    {% if kakao_openchat_url %}
    <section class="connect-card" aria-labelledby="connect-oc">
      <div class="connect-head">
        <span class="connect-ico connect-ico-oc" aria-hidden="true">💬</span>
        <h2 class="connect-title" id="connect-oc">카카오톡 오픈채팅</h2>
      </div>
      <p class="connect-desc">실시간 소식과 자유로운 논의는 오픈채팅방에서 함께해요.</p>
      <a class="kakao-btn" href="{{ kakao_openchat_url }}" target="_blank" rel="noreferrer">
        <svg class="kakao-ico" viewBox="0 0 24 24" aria-hidden="true"><path fill="#3C1E1E" d="M12 3.4C6.9 3.4 2.8 6.7 2.8 10.8c0 2.6 1.7 4.9 4.3 6.2-.2.7-.7 2.5-.8 2.9-.1.5.2.5.4.4.2-.1 2.4-1.6 3.4-2.3.6.1 1.2.1 1.9.1 5.1 0 9.2-3.3 9.2-7.3S17.1 3.4 12 3.4z"/></svg>
        카카오톡 오픈채팅 참여
      </a>
    </section>
    {% endif %}
  </div>
</footer>
{% endblock %}
