{% extends "base.html.j2" %}
{% block content %}
<header class="topbar">
  <div class="topbar-inner">
    <span class="brand">{{ site_title }}</span>
    <span class="tagline">네이버 세계뉴스 권역별 일일 브리핑</span>
    <button id="theme-toggle" class="iconbtn" type="button" aria-label="테마 전환" title="테마 전환"></button>
  </div>
</header>

<main class="wrap">
  {% if not days %}
    <p class="empty">아직 브리핑이 없습니다.</p>
  {% else %}
  <p class="daymeta">전체 {{ days|length }}일치</p>
  <ul class="date-list">
    {% for d in days %}
    <li class="date-card">
      <a class="date-main" href="{{ d.day }}.html">
        <span class="date">{{ d.day }}</span>
        <span class="count">{{ d.total }}건</span>
      </a>
      <div class="regions">
        {% for region, n in d.regions.items() %}<span class="chip-stat">{{ region }} <b>{{ n }}</b></span>{% endfor %}
      </div>
    </li>
    {% endfor %}
  </ul>
  {% endif %}
</main>
{% endblock %}
