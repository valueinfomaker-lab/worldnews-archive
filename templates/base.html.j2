<!doctype html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% block title %}{{ site_title }}{% endblock %}</title>
<link rel="icon" href="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%2048%2048'%3E%3Cpath%20d='M37.1%2014.8%20A16%2016%200%201%200%2037.1%2033.2'%20fill='none'%20stroke='%231a5490'%20stroke-width='3.4'%20stroke-linecap='round'/%3E%3Cellipse%20cx='24'%20cy='24'%20rx='7.2'%20ry='16'%20fill='none'%20stroke='%231a5490'%20stroke-width='1.3'%20opacity='0.45'/%3E%3Cpath%20d='M24%2024%20L33.5%2024'%20fill='none'%20stroke='%231a5490'%20stroke-width='3.4'%20stroke-linecap='round'/%3E%3Ccircle%20cx='33.8'%20cy='24'%20r='3'%20fill='%23d99f45'/%3E%3C/svg%3E">
<link rel="stylesheet" href="assets/style.css">
<script>
/* 테마 조기 적용(깜빡임 방지). localStorage 우선, 없으면 시스템 설정. */
(function () {
  try {
    var t = localStorage.getItem("theme");
    if (t !== "dark" && t !== "light") {
      t = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
    }
    document.documentElement.setAttribute("data-theme", t);
  } catch (e) {}
})();
</script>
</head>
<body>
<svg width="0" height="0" style="position:absolute" aria-hidden="true"><defs>
  <symbol id="logo" viewBox="0 0 48 48">
    <path class="lg-ink" d="M 37.1 14.8 A 16 16 0 1 0 37.1 33.2"/>
    <ellipse class="lg-thin" cx="24" cy="24" rx="7.2" ry="16"/>
    <path class="lg-ink" d="M 24 24 L 33.5 24"/>
    <circle class="lg-gold" cx="33.8" cy="24" r="3"/>
  </symbol>
</defs></svg>
<div id="toast" class="toast" role="status" aria-live="polite" hidden></div>
{% block content %}{% endblock %}
<button id="to-top" class="to-top" type="button" aria-label="맨 위로" hidden>↑</button>
<script src="assets/copy.js"></script>
<script src="assets/ui.js"></script>
</body>
</html>
